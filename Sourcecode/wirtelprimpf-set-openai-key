#!/usr/bin/env bash
set -euo pipefail

env_file="${1:-${HOME}/.config/wirtelprimpf/openai.env}"
config_dir="$(dirname "$env_file")"

mkdir -p "$config_dir"
chmod 700 "$config_dir"

printf 'OpenAI API key with Images permission (api.model.images.request): '
IFS= read -r -s api_key
printf '\n'

if [[ -z "$api_key" ]]; then
  printf 'No API key entered; nothing changed.\n' >&2
  exit 1
fi

umask 077
tmp_file="$(mktemp "${env_file}.XXXXXX")"
printf 'OPENAI_API_KEY=%q\n' "$api_key" > "$tmp_file"
mv "$tmp_file" "$env_file"
chmod 600 "$env_file"

printf 'Saved: %s\n' "$env_file"
