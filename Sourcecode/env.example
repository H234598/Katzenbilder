# Copy this file to a private environment file, then fill in your values.
# Never commit real API keys.

OPENAI_API_KEY=replace-me

# Where generated images and prompt text files are saved locally.
WIRTELPRIMPF_LOCAL_OUTDIR=$HOME/Pictures/Wirtelprimpf

# Optional GitHub publishing. Leave WIRTELPRIMPF_REPO_PATH unset to generate
# locally only.
WIRTELPRIMPF_REPO_PATH=$HOME/.local/share/wirtelprimpf/github/repository
WIRTELPRIMPF_REPO_SLUG=OWNER/REPOSITORY
WIRTELPRIMPF_REPO_SUBDIR=Wirtelprimpf
WIRTELPRIMPF_REPO_BRANCH=main

# Git commit identity used for generated image commits.
WIRTELPRIMPF_GIT_AUTHOR_NAME=Wirtelprimpf Bot
WIRTELPRIMPF_GIT_AUTHOR_EMAIL=wirtelprimpf@example.invalid

# OpenAI image settings.
WIRTELPRIMPF_IMAGE_MODEL=gpt-image-2
WIRTELPRIMPF_IMAGE_SIZE=1024x1024
